# .env
# Application settings — override defaults here to avoid modifying code

# Number of worker threads for CPU-bound document extraction (defaults to CPU cores * 2)
# MAX_WORKERS=8

# Maximum concurrent URL downloads to prevent network saturation
MAX_CONCURRENT_DOWNLOADS=10

# HTTP download timeout in seconds
DOWNLOAD_TIMEOUT_SECONDS=30

# Maximum file size allowed for downloads and uploads (in MB)
MAX_FILE_SIZE_MB=50

# Overall request timeout
REQUEST_TIMEOUT_SECONDS=120

# Minimal logging: set to WARNING or ERROR to suppress standard INFO logs (does not write to files)
LOG_LEVEL=WARNING
